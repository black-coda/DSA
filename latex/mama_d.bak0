\section{IMAGE 1: Basic Macroeconomics Concepts}
%=====================================================

\subsection{Question 1: Consumption Function and Determinants}

\subsubsection*{The Consumption Function}
The consumption function describes the relationship between consumption expenditure and disposable income:

\begin{equation}
C = a + bY_d
\end{equation}

Where:
\begin{itemize}
    \item $C$ = Total consumption expenditure
    \item $a$ = Autonomous consumption (consumption when income is zero)
    \item $b$ = Marginal Propensity to Consume (MPC)
    \item $Y_d$ = Disposable income
\end{itemize}

\subsubsection*{Determinants of Consumption Expenditure}
\begin{center}
\begin{tabular}{@{}p{4cm}p{10cm}@{}}
\toprule
\textbf{Factor} & \textbf{Explanation} \\
\midrule
Disposable Income & Primary determinant; as income rises, consumption rises (but less than proportionately) \\
\addlinespace
Wealth & Higher wealth increases consumption (wealth effect) \\
\addlinespace
Interest Rates & Higher rates encourage saving, reducing current consumption \\
\addlinespace
Expectations & Optimistic future expectations increase current spending \\
\addlinespace
Inflation & Expected inflation may increase current consumption \\
\addlinespace
Distribution of Income & More equal distribution increases aggregate consumption \\
\addlinespace
Demographic Factors & Age structure, family size affect consumption patterns \\
\addlinespace
Government Policies & Taxation and social security affect disposable income \\
\bottomrule
\end{tabular}
\end{center}

%-----------------------------------------------------

\subsection{Question 2: Circular Flow of Income in a Closed Economy}

\subsubsection*{The Circular Flow Model}
The circular flow model illustrates how money, goods, and services flow between households and firms in a closed economy (no foreign trade).

\begin{center}
\begin{tikzpicture}[scale=0.9]
    % Boxes
    \draw[thick, fill=blue!10] (0,0) rectangle (3,2) node[midway, align=center] {\textbf{HOUSEHOLDS}\\(Own factors of\\production)};
    \draw[thick, fill=green!10] (8,0) rectangle (11,2) node[midway, align=center] {\textbf{FIRMS}\\(Produce goods\\\& services)};
    
    % Top arrow (Factor payments)
    \draw[->, thick] (3,1.5) -- (8,1.5) node[midway, above] {Factor Payments};
    \node at (5.5,1.8) {\small (Rent, Wages, Interest, Profits)};
    
    % Bottom arrow (Consumption)
    \draw[->, thick] (8,0.5) -- (3,0.5) node[midway, below] {Consumption Expenditure (C)};
    
    % Side arrows (Goods and services)
    \draw[->, thick] (9.5,0) -- (9.5,-1) -- (1.5,-1) -- (1.5,0);
    \node at (5.5,-1.3) {Goods and Services};
\end{tikzpicture}
\end{center}

\subsubsection*{Leakages (Withdrawals)}
These reduce the flow of income:
\begin{itemize}
    \item \textbf{Saving (S)} -- Income not spent on consumption
    \item \textbf{Taxes (T)} -- In a three-sector model with government
    \item \textbf{Imports (M)} -- In an open economy
\end{itemize}

\subsubsection*{Injections}
These add to the flow of income:
\begin{itemize}
    \item \textbf{Investment (I)} -- Spending on capital goods
    \item \textbf{Government Spending (G)} -- In a three-sector model
    \item \textbf{Exports (X)} -- In an open economy
\end{itemize}

\subsubsection*{Equilibrium Condition}
\begin{equation}
\text{Leakages} = \text{Injections} \quad \Rightarrow \quad S + T + M = I + G + X
\end{equation}

%-----------------------------------------------------

\subsection{Question 3: Nominal vs. Real National Income}

\begin{center}
\begin{tabular}{@{}p{4cm}p{5cm}p{5cm}@{}}
\toprule
\textbf{Aspect} & \textbf{Nominal National Income} & \textbf{Real National Income} \\
\midrule
Definition & National income measured at current market prices & National income measured at constant (base year) prices \\
\addlinespace
Formula & Current quantity $\times$ Current prices & Current quantity $\times$ Base year prices \\
\addlinespace
Adjustment & No adjustment for inflation & Adjusted for inflation using price index \\
\addlinespace
Comparison & Cannot compare across time periods & Enables meaningful comparison over time \\
\addlinespace
Value & May rise due to price increases alone & Reflects actual change in output/volume \\
\bottomrule
\end{tabular}
\end{center}

\subsubsection*{Relationship}
\begin{equation}
\text{Real National Income} = \frac{\text{Nominal National Income}}{\text{Price Index}} \times 100
\end{equation}

\subsubsection*{Uses of National Income Statistics}
\begin{enumerate}
    \item \textbf{Economic Planning} -- Helps government formulate development plans
    \item \textbf{Standard of Living Comparison} -- Per capita income indicates living standards
    \item \textbf{International Comparisons} -- Compare economic performance across countries
    \item \textbf{Policy Formulation} -- Guides fiscal and monetary policies
    \item \textbf{Resource Allocation} -- Shows sectoral contributions to GDP
    \item \textbf{Investment Decisions} -- Helps investors assess market potential
    \item \textbf{Employment Analysis} -- Relationship with employment levels
    \item \textbf{Income Distribution} -- Analysis of inequality
\end{enumerate}

%-----------------------------------------------------

\subsection{Question 4: Expenditure Approach and Standard of Living}

\subsubsection*{a) Expenditure Approach to National Income Measurement}
The expenditure approach calculates GDP by summing all final expenditures:

\begin{equation}
GDP = C + I + G + (X - M)
\end{equation}

\begin{center}
\begin{tabular}{@{}p{2cm}p{11cm}@{}}
\toprule
\textbf{Component} & \textbf{Description} \\
\midrule
$C$ (Consumption) & Household spending on goods and services (durable, non-durable, services) \\
\addlinespace
$I$ (Investment) & Business spending on capital goods, residential construction, inventory changes \\
\addlinespace
$G$ (Government) & Government spending on goods and services (excluding transfers) \\
\addlinespace
$X$ (Exports) & Goods and services sold to foreign countries \\
\addlinespace
$M$ (Imports) & Goods and services purchased from foreign countries (subtracted) \\
\bottomrule
\end{tabular}
\end{center}

\subsubsection*{b) Relationship Between National Income and Standard of Living}

\begin{center}
\begin{tabular}{@{}p{6cm}p{6cm}@{}}
\toprule
\textbf{Positive Aspects} & \textbf{Limitations} \\
\midrule
Higher per capita income enables better access to goods/services & Does not account for income distribution (inequality) \\
\addlinespace
Allows investment in healthcare, education, infrastructure & Ignores non-market activities (household work, volunteer services) \\
\addlinespace
Reduces poverty levels & Environmental costs not deducted (pollution, resource depletion) \\
\addlinespace
Provides employment opportunities & Does not measure leisure time or working conditions \\
\addlinespace
Enables technological advancement & Quality improvements in goods not fully captured \\
\addlinespace
Improves housing and nutrition & Underground economy excluded \\
\bottomrule
\end{tabular}
\end{center}

\textbf{Conclusion:} National income is a useful but imperfect indicator of standard of living. The Human Development Index (HDI) provides a more comprehensive measure.

