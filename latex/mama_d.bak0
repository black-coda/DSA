\section{IMAGE 3 \& 4: Money, Wages and Banking}
%=====================================================

\subsection{Question 1: Money Wages vs. Real Wages}

\begin{center}
\begin{tabular}{@{}p{6cm}p{6cm}@{}}
\toprule
\textbf{Money Wages (Nominal Wages)} & \textbf{Real Wages} \\
\midrule
Wages measured in monetary terms & Wages measured in terms of purchasing power \\
\addlinespace
The actual amount of currency received & The quantity of goods and services wages can buy \\
\addlinespace
Not adjusted for inflation & Adjusted for inflation using price index \\
\addlinespace
Example: \#50,000 per month & Example: \#50,000 can buy 2 bags of rice \\
\bottomrule
\end{tabular}
\end{center}

\subsubsection*{Relationship}
\begin{equation}
\text{Real Wage} = \frac{\text{Money Wage}}{\text{Price Level}} \times 100
\end{equation}

\subsubsection*{Effects of Rising Urban Wages on Nigerian Economy}

\begin{center}
\begin{tabular}{@{}p{6cm}p{6cm}@{}}
\toprule
\textbf{Positive Effects} & \textbf{Negative Effects} \\
\midrule
\textbf{Increased Purchasing Power} -- Higher living standards for urban workers & \textbf{Rural-Urban Migration} -- Brain drain from agricultural sector \\
\addlinespace
\textbf{Increased Consumption} -- Boosts aggregate demand and economic growth & \textbf{Inflationary Pressure} -- Wage-price spiral if not matched by productivity \\
\addlinespace
\textbf{Attracts Investment} -- Skilled labor attracts foreign direct investment & \textbf{Income Inequality} -- Widening gap between urban and rural areas \\
\addlinespace
\textbf{Improved Productivity} -- Better-paid workers are more motivated & \textbf{Cost-Push Inflation} -- Higher production costs reduce competitiveness \\
\addlinespace
\textbf{Tax Revenue} -- Higher income tax revenue for government & \textbf{Unemployment} -- If wages rise above market-clearing level \\
\addlinespace
\textbf{Human Capital Development} -- Enables education and skill acquisition & \textbf{Dutch Disease} -- Over-reliance on urban sectors, neglect of agriculture \\
\bottomrule
\end{tabular}
\end{center}

%-----------------------------------------------------

\subsection{Question 2: Motives for Holding Money (Keynesian Liquidity Preference)}

\textbf{1. Transactions Motive:}
\begin{itemize}
    \item Money held for daily transactions and regular payments
    \item Directly related to income level
    \item $L_t = kY$ (where $k$ is a constant)
\end{itemize}

\textbf{2. Precautionary Motive:}
\begin{itemize}
    \item Money held for unforeseen emergencies and unexpected expenses
    \item Depends on income level and uncertainty
    \item $L_p = f(Y, \text{uncertainty})$
\end{itemize}

\textbf{3. Speculative Motive:}
\begin{itemize}
    \item Money held to take advantage of future changes in interest rates/bond prices
    \item Inversely related to interest rates
    \item $L_s = f(r)$ where $\frac{dL_s}{dr} < 0$
\end{itemize}

\subsubsection*{Total Demand for Money}
\begin{equation}
L = L_t + L_p + L_s = L_1(Y) + L_2(r)
\end{equation}

%-----------------------------------------------------

\subsection{Question 3: Central Bank of Nigeria (CBN) and Economic Development}

\begin{center}
\begin{tabular}{@{}p{4cm}p{10cm}@{}}
\toprule
\textbf{Function} & \textbf{Contribution to Development} \\
\midrule
Monetary Policy & Controls money supply and interest rates to maintain price stability, creating conducive environment for investment \\
\addlinespace
Banker to Government & Manages government accounts, facilitates deficit financing for development projects \\
\addlinespace
Banker to Banks & Acts as lender of last resort, ensures banking system stability \\
\addlinespace
Foreign Exchange Management & Manages external reserves, stabilizes exchange rate, facilitates international trade \\
\addlinespace
Development Finance & Through institutions like Bank of Industry (BOI), NEXIM Bank, provides long-term credit to key sectors \\
\addlinespace
Financial Inclusion & Promotes access to financial services, reducing poverty \\
\addlinespace
Payment System Oversight & Modernizes payment infrastructure (eNaira), reduces transaction costs \\
\addlinespace
Prudential Regulation & Supervises banks to prevent failures and protect depositors \\
\bottomrule
\end{tabular}
\end{center}

\textbf{Specific CBN Interventions:}
\begin{itemize}
    \item Anchor Borrowers' Programme (ABP) for agriculture
    \item Real Sector Support Facility (RSSF)
    \item COVID-19 intervention funds
    \item Micro, Small and Medium Enterprises Development Fund (MSMEDF)
\end{itemize}

%-----------------------------------------------------

\subsection{Question 4: Problems of Trade by Barter}

\textbf{Barter System:} Direct exchange of goods for goods without using money

\begin{center}
\begin{tabular}{@{}p{4cm}p{10cm}@{}}
\toprule
\textbf{Problem} & \textbf{Explanation} \\
\midrule
Double Coincidence of Wants & Both parties must want what the other has; difficult to find matching needs \\
\addlinespace
Indivisibility & Some goods cannot be divided into small units (e.g., a cow cannot be split for small transactions) \\
\addlinespace
Lack of Common Measure of Value & No standard unit to compare values of different goods \\
\addlinespace
Difficulty in Storing Wealth & Perishable goods lose value; no efficient way to save purchasing power \\
\addlinespace
No Standard for Deferred Payments & Impossible to lend or borrow, as future repayment value is uncertain \\
\addlinespace
Transportation Costs & Bulky goods are expensive and difficult to transport for exchange \\
\addlinespace
No Specialization & Everyone must produce a variety of goods to trade, reducing efficiency \\
\addlinespace
Transaction Costs & High time and effort spent searching for trading partners \\
\bottomrule
\end{tabular}
\end{center}

%-----------------------------------------------------

\subsection{Question 5: Quantity Theory of Money}

\subsubsection*{a) Irving Fisher's Equation of Exchange}

\textbf{Original Form:}
\begin{equation}
MV = PT
\end{equation}

Where:
\begin{center}
\begin{tabular}{@{}p{2cm}p{12cm}@{}}
\toprule
\textbf{Symbol} & \textbf{Meaning} \\
\midrule
$M$ & Money supply in circulation \\
$V$ & Velocity of circulation (average times money changes hands) \\
$P$ & General price level \\
$T$ & Total volume of transactions \\
\bottomrule
\end{tabular}
\end{center}

\textbf{Fisher's Modification (Income Version):}
\begin{equation}
MV = PY
\end{equation}

Where $Y$ = Real national income (output), replacing $T$

\textbf{Assumptions:}
\begin{itemize}
    \item $V$ is constant (determined by institutional factors)
    \item $Y$ is constant at full employment
    \item Therefore, changes in $M$ directly cause proportional changes in $P$
\end{itemize}

\subsubsection*{b) Critique of the Quantity Theory of Money}

\begin{center}
\begin{tabular}{@{}p{4cm}p{10cm}@{}}
\toprule
\textbf{Criticism} & \textbf{Explanation} \\
\midrule
Velocity is not constant & $V$ changes with financial innovations, payment habits, and interest rates \\
\addlinespace
Full employment assumption unrealistic & Economies often operate below full employment; increased $M$ can raise output \\
\addlinespace
Direction of causation & May be reverse: price changes cause money supply changes, not vice versa \\
\addlinespace
Hoarding & People may hold money idle, breaking the direct $M$-$P$ relationship \\
\addlinespace
Short-run vs. Long-run & Theory works better in long run; short-run price rigidities exist \\
\addlinespace
Ignores other factors & Ignores cost-push inflation, structural factors, and expectations \\
\addlinespace
Keynesian critique & In liquidity trap, increasing $M$ has no effect on prices or output \\
\addlinespace
Endogenous money & Modern banking creates money through lending, making $M$ less controllable \\
\bottomrule
\end{tabular}
\end{center}

