%=====================================================
\section{IMAGE 2: Consumption Theories and Calculations}
%=====================================================

\subsection{Question 1: Relative Income Hypothesis (Duesenberry)}

\textbf{Developed by:} James Duesenberry (1949)

\subsubsection*{Core Propositions}

\textbf{1. The Ratchet Effect:}
\begin{itemize}
    \item Consumers resist reducing their consumption levels when income falls
    \item Once a higher standard of living is achieved, people maintain it even if income declines
    \item Consumption depends on \textbf{past peak income} rather than current income
    \item Explains why consumption is more stable than income during recessions
\end{itemize}

\textbf{2. The Demonstration Effect (Keeping up with the Joneses):}
\begin{itemize}
    \item An individual's consumption is influenced by the consumption patterns of others in their social group
    \item People try to maintain their relative position in the income distribution
    \item Consumption depends on \textbf{relative income} position, not absolute income
\end{itemize}

\subsubsection*{Consumption Function}
\begin{equation}
\frac{C_t}{Y_t} = \alpha + \beta\left(\frac{Y_0}{Y_t}\right)
\end{equation}

Where $Y_0$ = previous peak income

\subsubsection*{Critical Evaluation}

\begin{center}
\begin{tabular}{@{}p{6cm}p{6cm}@{}}
\toprule
\textbf{Strengths} & \textbf{Weaknesses} \\
\midrule
Explains short-run rigidity of consumption & Difficult to empirically verify \\
\addlinespace
Accounts for consumer behavior during business cycles & Ignores role of liquid assets \\
\addlinespace
Recognizes social/psychological factors in consumption & Assumes consumption is irreversible \\
\addlinespace
Better explains reality than absolute income hypothesis & Does not explain saving behavior adequately \\
\addlinespace
Explains why APC may rise or fall & Limited predictive power \\
\bottomrule
\end{tabular}
\end{center}

%-----------------------------------------------------

\subsection{Question 2: Three-Sector Economy Calculations}

\textbf{Given:}
\begin{itemize}
    \item Autonomous consumption ($a$) = \#95 million
    \item Investment ($I$) = \#520 million
    \item Government expenditure ($G$) = \#250 million
    \item MPC ($b$) = 0.8
\end{itemize}

\textbf{The Consumption Function:} $C = 95 + 0.8Y$

\textbf{Equilibrium Condition:} $Y = C + I + G$

\subsubsection*{a) Equilibrium Level of National Income}

\begin{align}
Y &= C + I + G \\
Y &= (95 + 0.8Y) + 520 + 250 \\
Y &= 865 + 0.8Y \\
Y - 0.8Y &= 865 \\
0.2Y &= 865 \\
\boxed{Y = \text{\#4,325 million}}
\end{align}

\subsubsection*{b) Equilibrium Consumption Expenditure}

\begin{align}
C &= 95 + 0.8Y \\
C &= 95 + 0.8(4,325) \\
C &= 95 + 3,460 \\
\boxed{C &= \text{\#3,555 million}}
\end{align}

\textbf{Verification:} $C + I + G = 3,555 + 520 + 250 = 4,325 = Y$ \checkmark

\subsubsection*{c) Change in National Income when Investment Increases by 20\%}

\textbf{Step 1:} Calculate new investment
\begin{align}
\Delta I &= 20\% \times 520 = 0.20 \times 520 = \text{\#104 million} \\
I_{new} &= 520 + 104 = \text{\#624 million}
\end{align}

\textbf{Step 2:} Calculate the Multiplier
\begin{equation}
k = \frac{1}{1-MPC} = \frac{1}{1-0.8} = \frac{1}{0.2} = 5
\end{equation}

\textbf{Step 3:} Calculate change in national income
\begin{equation}
\Delta Y = k \times \Delta I = 5 \times 104 = \boxed{\text{\#520 million}}
\end{equation}

\textbf{New Equilibrium Income:} $4,325 + 520 = \text{\#4,845 million}$

